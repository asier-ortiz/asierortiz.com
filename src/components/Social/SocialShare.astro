---
import SocialIcon from '@components/Social/SocialIcon.astro';
import { generateSocialTags } from '@utils/transformTags';

interface Props {
  url: string;
  title: string;
  tags?: string[];
}

const { url, title, tags } = Astro.props as Props;

const hashtags = tags && tags.length > 0
  ? generateSocialTags(tags).map(tag => `#${tag}`).join(' ')
  : '';

const twitterText = hashtags ? `${title} ${hashtags}` : title;
const threadsText = `${title}\n\n${url}`;

const shareLinks = [
  {
    platform: 'twitter',
    link: `https://twitter.com/intent/tweet?url=${url}&text=${encodeURIComponent(twitterText)}`,
  },
  {
    platform: 'linkedin',
    link: `https://www.linkedin.com/shareArticle?url=${url}&title=${encodeURIComponent(title)}`,
  },
  {
    platform: 'facebook',
    link: `https://www.facebook.com/sharer/sharer.php?u=${url}`,
  },
  {
    platform: 'threads',
    link: `https://www.threads.net/intent/post?text=${encodeURIComponent(threadsText)}`,
  },
];
---

<div class="flex items-center gap-4 mt-8">
  <span class="text-base-400 text-sm">Share:</span>

  {shareLinks.map((share) => (
    <SocialIcon href={share.link} social={share.platform} />
  ))}

  <button
    id="copy-link-btn"
    aria-label="Copy link"
    class="social-icon flex gap-2 p-1 hover:text-primary-600 transition-colors"
  >
    <svg
      id="copy-link-icon"
      xmlns="http://www.w3.org/2000/svg"
      class="icon"
      width="24"
      height="24"
      viewBox="0 0 24 24"
      stroke-width="2"
      stroke="currentColor"
      fill="none"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path stroke="none" d="M0 0h24v24H0z" fill="none" />
      <path d="M9 15l6 -6" />
      <path d="M11 6l.463 -.536a5 5 0 0 1 7.071 7.072l-.534 .464" />
      <path d="M13 18l-.397 .534a5.068 5.068 0 0 1 -7.127 0a4.972 4.972 0 0 1 0 -7.071l.524 -.463" />
    </svg>
    <svg
      id="copy-link-check"
      xmlns="http://www.w3.org/2000/svg"
      class="icon hidden"
      width="24"
      height="24"
      viewBox="0 0 24 24"
      stroke-width="2"
      stroke="currentColor"
      fill="none"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path stroke="none" d="M0 0h24v24H0z" fill="none" />
      <path d="M5 12l5 5l10 -10" />
    </svg>
  </button>
</div>

<script>
  const btn = document.getElementById('copy-link-btn');
  const linkIcon = document.getElementById('copy-link-icon');
  const checkIcon = document.getElementById('copy-link-check');

  btn?.addEventListener('click', async () => {
    await navigator.clipboard.writeText(window.location.href);
    linkIcon?.classList.add('hidden');
    checkIcon?.classList.remove('hidden');
    setTimeout(() => {
      checkIcon?.classList.add('hidden');
      linkIcon?.classList.remove('hidden');
    }, 2000);
  });
</script>
