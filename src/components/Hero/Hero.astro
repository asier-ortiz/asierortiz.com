---
import { Image } from 'astro:assets';
import heroImage from '@assets/images/asier-ortiz.webp';
import siteData from '@config/siteData.json';
---

<section id="hero" class="relative flex w-full z-[25]" data-aos="fade-up">
  <div class="container grid items-center gap-10 pt-24 md:pt-36 lg:pt-44 md:grid-cols-3 md:gap-20">
    <div class="mx-auto max-w-lg md:col-span-2 md:ml-0 md:max-w-full">
      <h1 class="h1">Hey, I'm <span class="text-gradient">{siteData.author.name}</span></h1>
      <p class="description mt-6">
        Full-stack developer with
        <span class="description font-semibold text-primary-300">
          5+ years of experience
        </span>
        building web and mobile products, from concept to production.
      </p>
    </div>
    <div class="mx-auto max-w-sm md:col-span-1 md:max-w-full">
      <div class="eclipse-wrapper aspect-square relative z-[25]">
        <div class="eclipse-ring"></div>
        <div class="overflow-hidden rounded-full">
          <Image
            src={heroImage}
            class="w-full object-cover rounded-full fade-in"
            alt="asier ortiz profile"
            loading="eager"
            width={600}
            densities={[1.5, 2]}
            oncontextmenu="return false"
          />
        </div>
      </div>
    </div>
  </div>
</section>

<style lang="scss">

  .eclipse-wrapper {
    position: relative;
    border-radius: 50%;
  }

  .eclipse-ring {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    box-shadow:
      0 0 15px 3px rgba(var(--color-primary-600-rgb), 0.15),
      0 0 35px 8px rgba(var(--color-primary-600-rgb), 0.08),
      0 0 60px 15px rgba(var(--color-primary-600-rgb), 0.04);
    animation: corona-breathe 5s ease-in-out infinite;
  }

  @keyframes corona-breathe {
    0%, 100% {
      box-shadow:
        0 0 15px 3px rgba(var(--color-primary-600-rgb), 0.15),
        0 0 35px 8px rgba(var(--color-primary-600-rgb), 0.08),
        0 0 60px 15px rgba(var(--color-primary-600-rgb), 0.04);
    }
    50% {
      box-shadow:
        0 0 20px 5px rgba(var(--color-primary-600-rgb), 0.22),
        0 0 45px 12px rgba(var(--color-primary-600-rgb), 0.12),
        0 0 70px 20px rgba(var(--color-primary-600-rgb), 0.06);
    }
  }

  /* Large desktops and monitors */
  @media (min-width: 1200px) {
    #hero .max-w-sm {
      max-width: 100%;
    }
  }

  /* Tablets in landscape mode */
  @media (max-width: 1199px) and (min-width: 992px) {
    #hero .max-w-sm {
      max-width: 70%;
    }
  }

  /* Tablets in portrait mode and small desktops */
  @media (max-width: 991px) and (min-width: 768px) {
    #hero .max-w-sm {
      max-width: 70%;
    }
  }

  /* Smartphones in landscape mode */
  @media (max-width: 767px) and (min-width: 576px) {
    #hero .max-w-sm {
      max-width: 40%;
    }
  }

  /* Smartphones in portrait mode */
  @media (max-width: 575px) {
    #hero .max-w-sm {
      max-width: 40%;
    }
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const img = document.querySelector('img.fade-in');
    if (!img) return;

    if (img.complete) {
      img.classList.add('loaded');
    } else {
      img.addEventListener('load', () => {
        img.classList.add('loaded');
      });
    }
  });
</script>
